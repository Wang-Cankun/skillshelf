{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "skillshelf",
  "version": "0.2.0",
  "identifier": "dev.skillshelf.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "skillshelf",
        "width": 1280,
        "height": 820
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Wang-Cankun/skillshelf/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
