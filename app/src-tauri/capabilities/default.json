{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**", "app": true },
        { "path": "/Volumes/**", "app": true }
      ]
    },
    "opener:allow-reveal-item-in-dir",
    "dialog:allow-open",
    "updater:default",
    "process:default"
  ]
}
